<!DOCTYPE html>
<html>
  <head>
    <title>Showcase</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag_dynamic %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
    @page {
      size: letter portrait;
      margin: 0;
      padding: 0;
    }
    </style>
  </head>

  <body>
    <% @people.each_slice(8).each do |page| %>
    <div class="grid grid-cols-2 grid-rows-4 h-screen w-screen">
      <% page.each do |person| %>
      <div class="flex flex-col items-center justify-center border border-dashed border-gray-300 p-4">
        <div class="text-3xl font-bold mb-2"><%= person.display_name %></div>
        <div class="text-xl mb-2"><%= person.package&.name %></div>
        <div class="text-lg text-gray-600"><%= @event.name %></div>
      </div>
      <% end %>
    </div>
    <% end %>
  </body>
</html>
